{
	"name": "server",
	"main": "src/index.ts",
	"type": "module",
	"scripts": {
		"build": "tsdown",
		"check-types": "tsc -b",
		"compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
		"dev": "bun run --hot src/index.ts",
		"start": "bun run dist/index.mjs"
	},
	"dependencies": {
		"@fastify/cors": "^11.2.0",
		"@langchain/core": "0.3.80",
		"@langchain/langgraph": "0.2.68",
		"@langchain/openai": "0.4.5",
		"dotenv": "^17.2.2",
		"fastify": "^5.6.2",
		"ingest": "^1.0.0",
		"zod": "^4.1.13"
	},
	"devDependencies": {
		"@ai-writing-agent/config": "workspace:*",
		"@types/bun": "^1.2.6",
		"tsdown": "^0.16.5",
		"typescript": "^5.8.2"
	}
}
